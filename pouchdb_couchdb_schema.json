  "design_documents": {
    "location_views": {
      "_id": "_design/locations",
      "views": {
        "by_code": {
          "map": "function(doc) { if(doc.type === 'location') emit(doc.location_name, doc); }"
        },
        "by_district": {
          "map": "function(doc) { if(doc.type === 'location') emit(doc.hierarchy.district, doc); }"
        },
        "by_taluk": {
          "map": "function(doc) { if(doc.type === 'location') emit([doc.hierarchy.district, doc.hierarchy.taluk], doc); }"
        }
      }
    },

    "distribution_views": {
      "_id": "_design/distributions",
      "views": {
        "by_ration_card": {
          "map": "function(doc) { if(doc.type === 'distribution') emit(doc.ration_card_id, doc); }"
        },
        "by_location_date": {
          "map": "function(doc) { if(doc.type === 'distribution') emit([doc.location, doc.distribution_date], doc); }"
        },
        "by_month": {
          "map": "function(doc) { if(doc.type === 'distribution') emit([doc.distribution_year, doc.distribution_month], doc); }"
        },
        "by_sync_status": {
          "map": "function(doc) { if(doc.type === 'distribution') emit(doc.sync_status, doc); }"
        },
        "by_transaction_id": {
          "map": "function(doc) { if(doc.type === 'distribution') emit(doc.transaction_id, doc); }"
        }
      }
    },

    "sync_queue_views": {
      "_id": "_design/sync",
      "views": {
        "pending": {
          "map": "function(doc) { if(doc.type === 'sync_queue' && doc.status === 'PENDING') emit(doc.created_at, doc); }"
        },
        "by_device": {
          "map": "function(doc) { if(doc.type === 'sync_queue') emit(doc.device_id, doc); }"
        },
        "failed": {
          "map": "function(doc) { if(doc.type === 'sync_queue' && doc.status === 'FAILED') emit(doc.last_attempt, doc); }"
        }
      }
    },

    "complaint_views": {
      "_id": "_design/complaints",
      "views": {
        "by_status": {
          "map": "function(doc) { if(doc.type === 'complaint') emit(doc.status, doc); }"
        },
        "by_location": {
          "map": "function(doc) { if(doc.type === 'complaint') emit([doc.location, doc.created_at], doc); }"
        },
        "by_type": {
          "map": "function(doc) { if(doc.type === 'complaint') emit([doc.complaint_type, doc.status], doc); }"
        }
      }
    }
  },

  "indexes": {
    "pouchdb_indexes": [
      {
        "name": "by_transaction_id",
        "fields": ["type", "transaction_id"]
      },
      {
        "name": "by_ration_month_year",
        "fields": ["type", "ration_card_id", "distribution_year", "distribution_month"]
      },
      {
        "name": "by_device_date",
        "fields": ["type", "device_id", "created_at"]
      },
      {
        "name": "by_sync_status",
        "fields": ["type", "sync_status"]
      },
      {
        "name": "conflicts_by_ration",
        "fields": ["type", "ration_card_id", "conflict_type"]
      }
    ]
  },

  "replication_settings": {
    "continuous": true,
    "live": true,
    "retry": true,
    "batch_size": 100,
    "batches_limit": 5,
    "filter": "locations/sync_filter",
    "checkpoint_interval": 5000,
    "checkpoint_restart_on_resume": true,
    "conflict_strategy": "version_vector"
  }
}
